        {
          "name": "🚀 Bulk Create — 1000 Users (Performance Test)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/users/bulk-create",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "bulk-create"]
            },
            "body": {
              "mode": "raw",
              "raw": "{{generatedUsers}}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Dynamically generates 1000 unique users so the collection file",
                  "// stays readable. Emails/phones are seeded with a timestamp to",
                  "// avoid duplicate-key conflicts on repeated runs.",
                  "",
                  "const TOTAL = 1000;",
                  "const seed  = Date.now();",
                  "const deviceTypes = ['Mobile', 'Desktop'];",
                  "const osList      = ['Android', 'iOS', 'Windows', 'macOS'];",
                  "const kycList     = ['Pending', 'Approved', 'Rejected'];",
                  "",
                  "const users = [];",
                  "for (let i = 0; i < TOTAL; i++) {",
                  "    users.push({",
                  "        fullName:      'PerfUser ' + (i + 1),",
                  "        email:         'perfuser' + seed + '_' + i + '@loadtest.com',",
                  "        phone:         String(7000000000 + (seed % 1000000) + i).slice(0, 10),",
                  "        walletBalance: Math.floor(Math.random() * 10000),",
                  "        kycStatus:     kycList[i % 3],",
                  "        isBlocked:     i % 10 === 0,",
                  "        deviceInfo: {",
                  "            ipAddress:  '10.' + (i % 256) + '.' + (Math.floor(i/256) % 256) + '.1',",
                  "            deviceType: deviceTypes[i % 2],",
                  "            os:         osList[i % 4]",
                  "        }",
                  "    });",
                  "}",
                  "",
                  "pm.variables.set('generatedUsers', JSON.stringify(users));",
                  "console.log('Pre-request: generated ' + TOTAL + ' users for performance test.');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('All 1000 users created successfully', function () {",
                  "    const json = pm.response.json();",
                  "pm.expect(json.total).to.eql(1000);",
                  "});",
                  "",
                  "pm.test('Response time under 30sec for 1000 records', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(30000);",
                  "});",
                  "",
                  "// Log throughput so it's visible in the console",
                  "const elapsed = pm.response.responseTime;",
                  "console.log('1000-user bulk create completed in ' + elapsed + 'ms  (~' + Math.round(1000 / (elapsed / 1000)) + ' users/sec)');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
